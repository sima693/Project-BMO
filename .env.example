# BMO Configuration
# Copy this file to .env and fill in your values

# AI Backend: "ollama" (recommended, free/local) or "openai"
BMO_BACKEND=ollama

# Ollama model to use (must be pulled first: `ollama pull llama3.2`)
BMO_MODEL=llama3.2

# Ollama server URL (default is local)
OLLAMA_HOST=http://localhost:11434

# --- Only needed if BMO_BACKEND=openai ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
